<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="{{ description or site.tagline }}">
  <title>{% if title %}{{ title }} | {% endif %}{{ site.name }}</title>
  <link rel="stylesheet" href="{{ '/assets/css/style.css' | url }}">
</head>
<body>

  <div class="top-stripe"></div>

  <nav class="site-nav">
    <a href="{{ '/' | url }}" class="site-logo">
      <svg class="logo-mountain" width="30" height="20" viewBox="0 0 30 20" fill="none" aria-hidden="true">
        <path d="M1 19 L8 5 L11 10 L15 2 L19 10 L22 5 L29 19Z" fill="#0d1f3c" opacity="0.12"/>
        <path d="M1 19 L8 5 L12 12 L15 19Z" fill="#CC0000"/>
        <path d="M15 19 L18 12 L22 5 L29 19Z" fill="#002E5D"/>
        <path d="M11 10 L15 2 L19 10 L17 9 L15 5 L13 9Z" fill="#0d1f3c"/>
        <path d="M13.5 4.5 L15 2 L16.5 4.5 L15 4 Z" fill="white" opacity="0.9"/>
        <path d="M6.5 6.5 L8 4.5 L9.5 6.5 L8 6Z" fill="white" opacity="0.7"/>
        <path d="M20.5 6.5 L22 4.5 L23.5 6.5 L22 6Z" fill="white" opacity="0.7"/>
      </svg>
      Wasatch <span>Wire</span>
    </a>
    <ul class="nav-links">
      <li><a href="{{ '/' | url }}" {% if navActive == 'home' %}class="active"{% endif %}>Home</a></li>
      <li><a href="{{ '/wire/' | url }}" {% if navActive == 'wire' %}class="active"{% endif %}>Wire</a></li>
      <li><a href="{{ '/scores/' | url }}" {% if navActive == 'scores' %}class="active"{% endif %}>Scores</a></li>
      <li><a href="{{ '/standings/' | url }}" {% if navActive == 'standings' %}class="active"{% endif %}>Standings</a></li>
      <li><a href="{{ '/rankings/' | url }}" {% if navActive == 'rankings' %}class="active"{% endif %}>Rankings</a></li>
      <li><a href="{{ '/players/' | url }}" {% if navActive == 'players' %}class="active"{% endif %}>Players</a></li>
      <li><a href="{{ '/recruiting/' | url }}" {% if navActive == 'recruiting' %}class="active"{% endif %}>Recruiting</a></li>
      <li><a href="{{ '/holy-war/' | url }}" {% if navActive == 'holywar' %}class="active"{% endif %}>Holy War</a></li>
      <li><a href="{{ '/tabloids/' | url }}" {% if navActive == 'tabloids' %}class="active"{% endif %}>Tabloids</a></li>
      <li><a href="{{ '/archive/' | url }}" {% if navActive == 'archive' %}class="active"{% endif %}>Archive</a></li>
    </ul>
  </nav>

  {% if showTicker !== false %}
  <div class="ticker">
    <div class="ticker-inner">
      {% for item in ticker.items %}
        <div class="ticker-item"><span>{{ item }}</span></div>
        <div class="ticker-sep">·</div>
      {% endfor %}
      {% for item in ticker.items %}
        <div class="ticker-item"><span>{{ item }}</span></div>
        <div class="ticker-sep">·</div>
      {% endfor %}
    </div>
  </div>
  {% endif %}

  <main>
    {{ content | safe }}
  </main>

  <footer class="site-footer">
    <div class="footer-mountain" aria-hidden="true">
      <svg width="100%" height="60" viewBox="0 0 1100 60" preserveAspectRatio="none" fill="none">
        <path d="M0 60 L80 20 L140 40 L220 5 L300 35 L380 15 L460 45 L540 8 L620 38 L700 18 L780 42 L860 10 L940 32 L1020 22 L1100 38 L1100 60Z" fill="rgba(255,255,255,0.04)"/>
        <path d="M0 60 L100 30 L180 48 L260 18 L340 42 L420 25 L500 50 L580 15 L660 44 L740 28 L820 48 L900 20 L980 38 L1060 28 L1100 35 L1100 60Z" fill="rgba(255,255,255,0.06)"/>
      </svg>
    </div>
    <div class="footer-inner">
      <div class="footer-logo">
        <svg width="22" height="15" viewBox="0 0 30 20" fill="none" aria-hidden="true" style="display:inline-block;vertical-align:middle;margin-right:6px;">
          <path d="M1 19 L8 5 L12 12 L15 19Z" fill="#CC0000" opacity="0.8"/>
          <path d="M15 19 L18 12 L22 5 L29 19Z" fill="#4488cc" opacity="0.8"/>
          <path d="M11 10 L15 2 L19 10 L17 9 L15 5 L13 9Z" fill="white" opacity="0.6"/>
          <path d="M13.5 4.5 L15 2 L16.5 4.5 L15 4Z" fill="white" opacity="0.9"/>
        </svg>
        Wasatch <span>Wire</span>
      </div>
      <div>{{ site.name }} · Big 12 Dynasty · Season {{ site.season }}</div>
    </div>
  </footer>

</body>
</html>
