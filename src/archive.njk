---
layout: base.njk
title: Archive
navActive: archive
---
<div class="container">
  <div class="page-header">
    <h1 class="page-title">Archive</h1>
    <div class="page-subtitle">Every article from Season {{ site.season }} — oldest to latest</div>
  </div>

  <div class="wire-list">
    {% set allArticles = collections.articles | reverse %}
    {% for article in allArticles %}
    <div class="wire-article-row">
      <div class="wire-article-thumb">
        {% if article.data.image %}
          <img src="{{ article.data.image }}" alt="{{ article.data.title }}">
        {% else %}
          <div style="width:100%;height:100%;background:var(--surface-2);display:flex;align-items:center;justify-content:center;font-size:11px;color:var(--text-muted);">No img</div>
        {% endif %}
      </div>
      <div class="wire-article-info">
        <div class="article-tag {% if article.data.team %}{{ article.data.team }}{% endif %}">
          {{ article.data.category or "Wire" }}{% if article.data.week %} · Week {{ article.data.week }}{% endif %}
        </div>
        <div class="article-headline">
          <a href="{{ article.url | url }}">{{ article.data.title }}</a>
        </div>
        {% if article.data.deck %}
        <div class="article-deck">{{ article.data.deck }}</div>
        {% endif %}
        <div class="article-byline">Wasatch Wire · {{ article.data.date | dateDisplay }}</div>
      </div>
    </div>
    {% else %}
    <div style="color:var(--text-muted); font-size:14px; padding:24px 0;">No archived articles yet.</div>
    {% endfor %}
  </div>
</div>
