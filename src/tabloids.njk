---
layout: base.njk
title: Tabloids
navActive: tabloids
---
<div class="container">
  <div class="page-header">
    <h1 class="page-title">Tabloids</h1>
    <div class="page-subtitle">Player drama, campus scandals, and dynasty gossip</div>
  </div>

  <div class="wire-list">
    {% for article in collections.tabloids %}
    <div class="wire-article-row">
      <div class="wire-article-thumb">
        {% if article.data.image %}
          <img src="{{ article.data.image }}" alt="{{ article.data.title }}">
        {% else %}
          No image
        {% endif %}
      </div>
      <div class="wire-article-info">
        <div class="article-tag tabloids">{{ article.data.category or "Tabloids" }}</div>
        <div class="article-headline">
          <a href="{{ article.url | url }}">{{ article.data.title }}</a>
        </div>
        {% if article.data.deck %}
        <div class="article-deck">{{ article.data.deck }}</div>
        {% endif %}
        <div class="article-byline">Wasatch Wire · {{ article.data.date | dateDisplay }}</div>
      </div>
    </div>
    {% else %}
    <div style="color:var(--text-muted); font-size:14px; padding:24px 0;">No tabloid stories yet. Give it time.</div>
    {% endfor %}
  </div>
</div>
